# Copy to .env (gitignored) and fill in the values.
# Loaded automatically by Spring Boot via `spring.config.import` in application.yml.
# The app must run with the repository root as the working directory so that
# the relative path `apps/api/.env` resolves. See docs/dev-setup.md.

# OAuth2 client secret for the Pecunia BFF.
# Dev value must match the `secret` field of the pecunia-bff client
# in deploy/keycloak/pecunia-realm.json.
PECUNIA_BFF_CLIENT_SECRET=pecunia-bff-dev-secret

# Activates the `dev` Spring profile (enables Swagger UI, future dev-only overrides).
spring.profiles.active=dev
